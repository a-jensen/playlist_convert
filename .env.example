# Spotify — required for Spotify commands
# Create an app at https://developer.spotify.com/dashboard
# Add http://localhost:8888/callback as a Redirect URI in the app settings
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Apple Music — optional, only needed if the library is not in the default location
# Default locations checked:
#   ~/Music/Music/Music Library.musiclibrary/Library.musiclibrary  (modern macOS)
#   ~/Music/iTunes/iTunes Music Library.xml                         (legacy iTunes)
# APPLE_LIBRARY_PATH=/path/to/your/Library.musiclibrary

# Matching — lower this value (e.g. 70) to accept looser matches, raise it for stricter matching
FUZZY_MATCH_THRESHOLD=85.0
